{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SystemArchitecture": {
    "EvolutionFrameworkPackage": "DevelApp.SelfEvolvingFramework",
    "EvolutionFrameworkVersion": "1.3.0",
    "DatabaseProvider": "PostgreSQL",
    "DatabaseConnectionString": "Host=localhost;Port=5432;Database=asset_management;Username=asset_user;******",
    "BlazorWebAssemblyEnabled": true,
    "BlazorServerEnabled": true,
    "EvolutionExecutionBudgetMilliseconds": 30000,
    "EvolutionMinimumFitnessScore": 0.8,
    "MultiAgentEnabled": false,
    "MultiAgentSystemMode": "Cloud",
    "MultiAgentMaxParallelAgents": 6,
    "MultiAgentRunTimeoutMs": 5000,
    "MultiAgentSafetyBlockThreshold": 0.6,
    "MultiAgentRequireHumanApproval": true,
    "OpaPolicyBundlePath": "policies/asset-create-policy.json",
    "OpaPolicyBundleVersion": "v1.1.0"
  }
}
